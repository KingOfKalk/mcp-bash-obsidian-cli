{
  "name": "kingofkalk-mcp-bash-obsidian-cli",
  "description": "MCP server (stdio) wrapping the Obsidian CLI, written in Bash.",
  "author": {
    "name": "KingOfKalk"
  },
  "homepage": "https://github.com/KingOfKalk/mcp-bash-obsidian-cli",
  "repository": "https://github.com/KingOfKalk/mcp-bash-obsidian-cli",
  "license": "MIT",
  "keywords": [
    "obsidian",
    "mcp",
    "bash",
    "notes",
    "knowledge-management"
  ],
  "mcpServers": {
    "obsidian": {
      "command": "${CLAUDE_PLUGIN_ROOT}/obsidian-mcp.sh",
      "args": ["${OBSIDIAN_VAULT:-default}"],
      "env": {
        "OBSIDIAN_BIN": "${OBSIDIAN_BIN:-obsidian}",
        "OBSIDIAN_MCP_LOG": "${OBSIDIAN_MCP_LOG:-}"
      }
    }
  }
}
